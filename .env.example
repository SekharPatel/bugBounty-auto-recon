# ============================================================
# Recon Watch Multi - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All paths can be absolute or relative to the script directory.
# ============================================================

# --- Directories & File Paths ---
ROOT_DIR=recon_watch_data

# --- Notifications ---
NOTIFY_BIN=notify
NOTIFY_ID=
NOTIFY_STEP_BY_STEP=true

# --- Tool Binary Paths (defaults to tool name if in PATH) ---
SUBFINDER_BIN=subfinder
HTTPX_BIN=httpx
NAABU_BIN=naabu
NUCLEI_BIN=nuclei
KATANA_BIN=katana

# --- Scan Options ---
NUCLEI_SEVERITIES=medium,high,critical
KATANA_DEPTH=3
KATANA_HEADLESS=false
KATANA_CRAWL_JS=true

# --- Custom Arguments ---
# Supply extra arguments natively. e.g. SUBFINDER_ARGS="-all -active"
SUBFINDER_ARGS=""
HTTPX_ARGS=""
NAABU_ARGS=""
NUCLEI_ARGS=""
KATANA_ARGS=""
NOTIFY_ARGS=""

# --- Timeouts (seconds) ---
SUBFINDER_TIMEOUT=3600
HTTPX_TIMEOUT=1800
NAABU_TIMEOUT=3600
NUCLEI_TIMEOUT=3600
KATANA_TIMEOUT=3600

# --- Maintenance ---
# Auto-delete scan artifact directories older than this many days (0 = disable)
MAX_JOB_RETENTION_DAYS=30

# --- Debug ---
# Set to true to skip running external tools (subfinder, httpx, etc.)
DRY_RUN=false
