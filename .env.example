# ============================================================
# Recon Watch Multi - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All paths can be absolute or relative to the script directory.
# ============================================================

# --- Directories & File Paths ---
ROOT_DIR=recon_watch_data

# --- Notifications ---
NOTIFY_ID=
NOTIFY_STEP_BY_STEP=true

# --- Tool Binary Paths (defaults to tool name if in PATH) ---
SUBFINDER_BIN=subfinder
HTTPX_BIN=httpx
NAABU_BIN=naabu
NUCLEI_BIN=nuclei
KATANA_BIN=katana
NOTIFY_BIN=notify

# --- Scan Options ---
NUCLEI_SEVERITIES=medium,high,critical
NAABU_NMAP_CLI=false
KATANA_DEPTH=2
KATANA_HEADLESS=false
KATANA_CRAWL_JS=false
KATANA_FIELD_SCOPE=rdn
KATANA_CUSTOM_SCOPE=

# --- Custom Arguments ---
# Supply extra arguments natively. e.g. SUBFINDER_ARGS="-active"
SUBFINDER_ARGS=""
HTTPX_ARGS=""
NAABU_ARGS=""
NUCLEI_ARGS=""
KATANA_ARGS=""
NOTIFY_ARGS=""

# --- Timeouts (seconds) ---
SUBFINDER_TIMEOUT=600
HTTPX_TIMEOUT=600
NAABU_TIMEOUT=600
NUCLEI_TIMEOUT=1200
KATANA_TIMEOUT=900

# --- Maintenance ---
# Auto-delete scan artifact directories older than this many days (0 = disable)
MAX_JOB_RETENTION_DAYS=30

# --- Debug ---
# Set to true to skip running external tools (subfinder, httpx, etc.)
DRY_RUN=false
